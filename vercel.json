{
  "version": 2,
  "builds": [
    {
      "src": "api/generate.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "api/generate.py"
    }
  ],
  "env": {
    "CLOUDINARY_CLOUD": "dx4wlvbxt",
    "CLOUDINARY_UPLOAD_PRESET": "alpuerta_test"
  },
  "functions": {
    "api/generate.py": {
      "maxDuration": 60
    }
  }
}
